    <div class="scroll-hint">
        <div class="scroll-line"></div>
        <span>scroll</span>
    </div>
</section>

<script>
    const roles = ['Full Stack Developer', 'DevOps', 'Project Management'];
    let i = 0, charIndex = 0, deleting = false;
    const el = document.getElementById('roleText');

    function type() {
        const current = roles[i];
        if (!deleting) {
            el.textContent = current.slice(0, charIndex + 1);
            charIndex++;
            if (charIndex === current.length) {
                deleting = true;
                setTimeout(type, 2200);
                return;
            }
        } else {
            el.textContent = current.slice(0, charIndex - 1);
            charIndex--;
            if (charIndex === 0) {
                deleting = false;
                i = (i + 1) % roles.length;
            }
        }
        setTimeout(type, deleting ? 45 : 85);
    }
    setTimeout(type, 1200);
</script>

<style>
    .hero {
        min-height: 100vh;
        background: #050810;
        position: relative;
        display: flex;
        align-items: center;
        overflow: hidden;
    }

    /* Subtle grid */
    .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
        background-size: 64px 64px;
        pointer-events: none;
    }

    /* Ambient glows */
    .bg-glow {
        position: absolute;
        border-radius: 50%;
        filter: blur(130px);
        pointer-events: none;
    }
    .bg-glow-1 {
        width: 700px; height: 700px;
        background: radial-gradient(circle, rgba(124, 58, 237, 0.15) 0%, transparent 70%);
        top: -150px; right: -150px;
    }
    .bg-glow-2 {
        width: 450px; height: 450px;
        background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%);
        bottom: -80px; left: 5%;
    }

    /* Layout */
    .hero-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2.5rem;
        width: 100%;
        display: grid;
        grid-template-columns: 55% 45%;
        gap: 2rem;
        align-items: center;
        position: relative;
        z-index: 2;
    }

    .hero-left {
        display: flex;
        flex-direction: column;
        padding: 2rem 0;
    }

    /* Badge */
    .availability-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        background: rgba(34, 197, 94, 0.07);
        border: 1px solid rgba(34, 197, 94, 0.18);
        color: #4ade80;
        padding: 0.45rem 1.1rem;
        border-radius: 50px;
        font-size: 0.78rem;
        font-weight: 600;
        margin-bottom: 2.2rem;
        width: fit-content;
        letter-spacing: 0.4px;
    }

    .dot {
        width: 7px; height: 7px;
        background: #4ade80;
        border-radius: 50%;
        flex-shrink: 0;
        animation: pulse 2.5s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.5); }
        50%       { box-shadow: 0 0 0 5px rgba(74, 222, 128, 0); }
    }

    /* Name */
    .hero-name {
        font-size: 5.8rem;
        font-weight: 900;
        color: white;
        line-height: 0.92;
        letter-spacing: -3px;
        margin-bottom: 1.6rem;
    }

    .gradient-text {
        background: linear-gradient(125deg, #a855f7 0%, #6366f1 45%, #38bdf8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* Role */
    .hero-role {
        font-family: 'Courier New', monospace;
        font-size: 1rem;
        color: rgba(255,255,255,0.45);
        margin-bottom: 1.8rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .role-prefix { color: #7c3aed; font-weight: 700; }

    #roleText { color: rgba(255,255,255,0.75); }

    .cursor {
        color: #a855f7;
        animation: blink 1.1s step-end infinite;
        line-height: 1;
    }

    @keyframes blink {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0; }
    }

    /* Description */
    .hero-desc {
        color: rgba(255,255,255,0.4);
        font-size: 0.98rem;
        line-height: 1.8;
        max-width: 430px;
        margin-bottom: 2.5rem;
    }

    /* Stats */
    .hero-stats {
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-bottom: 2.8rem;
    }

    .hero-stat { display: flex; flex-direction: column; gap: 0.25rem; }

    .stat-n {
        font-size: 1.9rem;
        font-weight: 800;
        color: white;
        line-height: 1;
        letter-spacing: -1px;
    }

    .stat-l {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.3);
        text-transform: uppercase;
        letter-spacing: 0.8px;
    }

    .stat-divider {
        width: 1px; height: 42px;
        background: rgba(255,255,255,0.08);
    }

    /* CTAs */
    .hero-ctas {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .cta-primary {
        padding: 0.9rem 2.2rem;
        background: linear-gradient(135deg, #9333ea, #6366f1);
        color: white;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.88rem;
        letter-spacing: 0.3px;
        transition: all 0.3s ease;
        box-shadow: 0 0 28px rgba(147, 51, 234, 0.35), inset 0 1px 0 rgba(255,255,255,0.15);
    }

    .cta-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 0 42px rgba(147, 51, 234, 0.55), inset 0 1px 0 rgba(255,255,255,0.15);
    }

    .cta-secondary {
        padding: 0.9rem 2.2rem;
        color: rgba(255,255,255,0.6);
        border-radius: 50px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.88rem;
        border: 1px solid rgba(255,255,255,0.1);
        transition: all 0.3s ease;
        letter-spacing: 0.3px;
    }

    .cta-secondary:hover {
        color: white;
        border-color: rgba(255,255,255,0.25);
        background: rgba(255,255,255,0.04);
        transform: translateY(-2px);
    }

    .cta-icon {
        width: 46px; height: 46px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.55);
        text-decoration: none;
        transition: all 0.3s ease;
        flex-shrink: 0;
    }

    .cta-icon:hover {
        color: white;
        border-color: rgba(255,255,255,0.4);
        background: rgba(255,255,255,0.06);
        transform: translateY(-2px);
    }

    .cta-icon-li:hover {
        border-color: rgba(10, 102, 194, 0.6);
        background: rgba(10, 102, 194, 0.12);
        color: #60a5fa;
    }

    /* Right side - photo */
    .hero-right {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 3rem 0;
    }

    .photo-frame {
        position: relative;
        width: 340px;
        height: 340px;
    }

    .photo-glow {
        position: absolute;
        inset: -20px;
        background: linear-gradient(135deg, rgba(147, 51, 234, 0.25), rgba(99, 102, 241, 0.15), rgba(56, 189, 248, 0.2));
        border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
        animation: morph 9s ease-in-out infinite;
        filter: blur(20px);
        z-index: 0;
    }

    .photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
        animation: morph 9s ease-in-out infinite;
        border: 1.5px solid rgba(168, 85, 247, 0.25);
        position: relative;
        z-index: 1;
    }

    @keyframes morph {
        0%   { border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%; }
        25%  { border-radius: 58% 42% 75% 25% / 76% 46% 54% 24%; }
        50%  { border-radius: 50% 50% 33% 67% / 55% 27% 73% 45%; }
        75%  { border-radius: 33% 67% 58% 42% / 63% 68% 32% 37%; }
        100% { border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%; }
    }

    /* Floating badges */
    .badge {
        position: absolute;
        background: rgba(12, 14, 25, 0.75);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 50px;
        padding: 0.5rem 1.1rem;
        font-size: 0.75rem;
        font-weight: 600;
        color: rgba(255,255,255,0.85);
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 0.45rem;
        z-index: 2;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    }

    .badge span { font-size: 0.9rem; }

    .badge-1 { top: 5px;    left: -80px;  animation: f1 4.2s ease-in-out infinite; }
    .badge-2 { top: 40px;   right: -85px; animation: f2 5.1s ease-in-out infinite; }
    .badge-3 { bottom: 50px; left: -90px; animation: f3 3.8s ease-in-out infinite; }
    .badge-4 { bottom: 5px;  right: -65px; animation: f4 4.7s ease-in-out infinite; }

    @keyframes f1 { 0%,100% { transform: translateY(0);   } 50% { transform: translateY(-9px);  } }
    @keyframes f2 { 0%,100% { transform: translateY(0);   } 50% { transform: translateY(11px);  } }
    @keyframes f3 { 0%,100% { transform: translateY(0);   } 50% { transform: translateY(-7px);  } }
    @keyframes f4 { 0%,100% { transform: translateY(0);   } 50% { transform: translateY(9px);   } }

    /* Scroll hint */
    .scroll-hint {
        position: absolute;
        bottom: 2.5rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        z-index: 2;
    }

    .scroll-line {
        width: 1px; height: 44px;
        background: linear-gradient(180deg, rgba(255,255,255,0.4), transparent);
        animation: scrollDrop 2.2s ease-in-out infinite;
        transform-origin: top;
    }

    .scroll-hint span {
        font-size: 0.62rem;
        text-transform: uppercase;
        letter-spacing: 2.5px;
        color: rgba(255,255,255,0.2);
    }

    @keyframes scrollDrop {
        0%   { opacity: 0; transform: scaleY(0); }
        40%  { opacity: 1; transform: scaleY(1); }
        100% { opacity: 0; transform: scaleY(1); }
    }

    /* Responsive */
    @media (max-width: 900px) {
        .hero-container {
            grid-template-columns: 1fr;
            text-align: center;
            padding: 7rem 2rem 5rem;
        }

        .hero-name { font-size: 4rem; letter-spacing: -2px; }
        .availability-badge, .hero-desc { margin-left: auto; margin-right: auto; }
        .hero-ctas, .hero-stats { justify-content: center; }

        .hero-right { padding: 1rem 0 2rem; }
        .photo-frame { width: 260px; height: 260px; }

        .badge-1 { left: -40px; }
        .badge-3 { left: -50px; }
        .badge-2 { right: -40px; }
        .badge-4 { right: -30px; }

        .scroll-hint { display: none; }
    }
</style>
