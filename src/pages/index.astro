---
import Layout from '../layouts/Layout.astro';
import Personal from '../components/Personal.astro';
import Projects from '../components/Projects.astro';
---

<Layout>
    <Personal />
    
    <!-- Services Section -->
    <section class="services">
        <div class="container">
            <div class="services-header">
                <span class="services-label">¿Qué hago?</span>
                <h2>Desarrollador <span class="highlight">Full Stack</span></h2>
            </div>

            <div class="services-grid">
                <div class="service-card">
                    <div class="card-num">01</div>
                    <div class="card-icon-wrap">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                    </div>
                    <h3>Frontend</h3>
                    <p>Interfaces modernas con foco en rendimiento, responsividad y experiencia de usuario. Trabajo con componentes reutilizables, diseño de sistemas UI y micro frontends.</p>
                    <div class="card-pills">
                        <span>Astro</span><span>React</span><span>Vue 3</span><span>Next.js</span><span>TypeScript</span><span>HTML/CSS</span><span>Tailwind</span>
                    </div>
                    <div class="card-shine"></div>
                </div>

                <div class="service-card">
                    <div class="card-num">02</div>
                    <div class="card-icon-wrap">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                    </div>
                    <h3>Backend & DevOps</h3>
                    <p>Sistemas distribuidos con microservicios, colas asíncronas y persistencia relacional. Despliegue containerizado en cloud y gestión de migraciones de datos.</p>
                    <div class="card-pills">
                        <span>Ruby on Rails</span><span>Spring Boot</span><span>Java</span><span>Express.js</span><span>FastAPI</span><span>Laravel</span><span>MySQL</span><span>RabbitMQ</span><span>Docker</span><span>AWS</span><span>Lua</span>
                    </div>
                    <div class="card-shine"></div>
                </div>

                <div class="service-card">
                    <div class="card-num">03</div>
                    <div class="card-icon-wrap ai-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.937A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.582a.5.5 0 0 1 0 .962L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z"/><path d="M20 3v4M22 5h-4"/></svg>
                    </div>
                    <h3>IA & Automatización</h3>
                    <p>Flujos de trabajo aumentados con IA aplicada al desarrollo. Diseño, composición y supervisión de agentes, skills y commands para acelerar y robustecer soluciones iterativamente.</p>
                    <div class="card-pills ai-pills">
                        <span>Claude Code</span><span>Skills</span><span>Commands</span><span>Agents</span>
                    </div>
                    <div class="card-shine"></div>
                </div>

                <div class="service-card">
                    <div class="card-num">04</div>
                    <div class="card-icon-wrap">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <h3>Colaboración & Equipos</h3>
                    <p>Trabajo efectivo en equipos técnicos usando GitHub Flow con ramas, pull requests y revisión de código. Comunicación directa con clientes internos, gestión ágil de tickets y ciclos de feedback cortos.</p>
                    <div class="card-pills">
                        <span>Git Flow</span><span>GitHub</span><span>Agile</span><span>Comunicación</span>
                    </div>
                    <div class="card-shine"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Experience & Skills Section -->
    <section class="experience">
        <div class="container">
            <div class="exp-grid">

                <!-- Columna 1: Timeline -->
                <div class="exp-col exp-col-timeline">
                    <p class="exp-col-label">Trayectoria</p>
                    <div class="job-timeline">
                        <div class="job-item current">
                            <div class="job-badge">Actual</div>
                            <div class="job-content">
                                <h3>Integration Analyst Jr.</h3>
                                <p class="company">Buk • Santiago, Chile</p>
                                <p class="period">Dic 2024 - Presente</p>
                                <p class="description">Desarrollo de integraciones en Ruby on Rails para archivos contables, vouchers personalizados y migración de bases de datos externas hacia Buk. Carga histórica de datos desde archivos <code>.bak</code> con reconciliación de fichas de empleados e ítems mediante software interno en C#. Gestión activa de tickets con contacto directo a clientes internos, entregando soluciones ágiles con ciclos de feedback cortos. Uso de flujos de trabajo aumentados con IA (Claude) para creación, supervisión y compounding de skills y commands, mejorando iterativamente la calidad y velocidad de las soluciones.</p>
                            </div>
                        </div>
                        <div class="job-item">
                            <div class="job-content">
                                <h3>IT Support Internship</h3>
                                <p class="company">FSM Ltda. • Viña del Mar</p>
                                <p class="period">Ene 2024 - Abr 2024</p>
                                <p class="description">Soporte técnico y optimización de procesos con IA. Uso de AutoCAD y sistemas ABB 800xA.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Columnas 2 y 3: par que se alinea entre sí -->
                <div class="exp-pair">

                <!-- Columna 2: Tecnologías -->
                <div class="exp-col">
                    <div class="skills-section">
                        <h3>Tecnologías</h3>
                        <div class="tech-grid">
                            <div class="tech-category cat-backend">
                                <h4>Backend</h4>
                                <div class="tech-tags">
                                    <span class="tech-tag">Ruby</span>
                                    <span class="tech-tag">Python</span>
                                    <span class="tech-tag">C#</span>
                                    <span class="tech-tag">Java</span>
                                    <span class="tech-tag">Laravel</span>
                                    <span class="tech-tag">Express.js</span>
                                    <span class="tech-tag">Spring Boot</span>
                                    <span class="tech-tag">FastAPI</span>
                                </div>
                            </div>
                            <div class="tech-category cat-frontend">
                                <h4>Frontend</h4>
                                <div class="tech-tags">
                                    <span class="tech-tag">JavaScript</span>
                                    <span class="tech-tag">HTML/CSS</span>
                                    <span class="tech-tag">Astro</span>
                                    <span class="tech-tag">Next.js</span>
                                </div>
                            </div>
                            <div class="tech-category cat-db">
                                <h4>Bases de Datos & Otros</h4>
                                <div class="tech-tags">
                                    <span class="tech-tag">SQL</span>
                                    <span class="tech-tag">Git</span>
                                    <span class="tech-tag">PHP</span>
                                    <span class="tech-tag">Lua</span>
                                    <span class="tech-tag">Vue 3</span>
                                    <span class="tech-tag">Docker</span>
                                    <span class="tech-tag">AWS</span>
                                </div>
                            </div>
                            <div class="tech-category cat-ai">
                                <h4>IA & Automatización</h4>
                                <div class="tech-tags">
                                    <span class="tech-tag">Claude Code</span>
                                    <span class="tech-tag">Skills</span>
                                    <span class="tech-tag">Commands</span>
                                    <span class="tech-tag">Agents</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Columna 3: Formación + Idiomas -->
                <div class="exp-col">
                    <div class="education-section">
                        <h3>Formación</h3>
                        <div class="education-item">
                            <h4>Ingeniería Informática <span class="edu-spec">Esp. Desarrollo de Software</span></h4>
                            <p class="edu-institution">Duoc UC</p>
                            <p class="edu-period">2026 — Actualidad</p>
                        </div>
                        <div class="education-item">
                            <h4>Ingeniería Informática</h4>
                            <p class="edu-institution">UTFSM</p>
                            <p class="edu-period">2024 — 2024 <span class="edu-note">Retiro por incompatibilidad con trabajo</span></p>
                        </div>
                        <div class="education-item">
                            <h4>Técnico Superior en Informática</h4>
                            <p class="edu-institution">UTFSM</p>
                            <p class="edu-period">2022 — 2023</p>
                        </div>
                    </div>
                    <div class="languages-section">
                        <h3>Idiomas</h3>
                        <div class="language-bars">
                            <div class="language-item">
                                <span class="language-name">Español</span>
                                <div class="language-bar"><div class="language-fill native"></div></div>
                                <span class="language-level">Nativo</span>
                            </div>
                            <div class="language-item">
                                <span class="language-name">Francés</span>
                                <div class="language-bar"><div class="language-fill intermediate"></div></div>
                                <span class="language-level">Intermedio</span>
                            </div>
                            <div class="language-item">
                                <span class="language-name">Inglés</span>
                                <div class="language-bar"><div class="language-fill medianamente"></div></div>
                                <span class="language-level">Intermedio</span>
                            </div>
                        </div>
                    </div>
                </div>

                </div><!-- /exp-pair -->
            </div>
        </div>
    </section>

    <Projects />

    <footer class="site-footer">
        <div class="footer-inner">
            <h2>Mi contacto</h2>
            <p>Siempre estoy abierto a nuevas oportunidades y proyectos interesantes. 😁</p>
            <div class="footer-contact">
                <a href="mailto:amaroeduard@gmail.com" class="footer-btn">
                    <span>📧</span>
                    amaroeduard@gmail.com
                </a>
                <a href="tel:+56979622341" class="footer-btn">
                    <span>📱</span>
                    +56 9 7962 2341
                </a>
                <a href="https://github.com/TomaTeQuila" target="_blank" rel="noopener" class="footer-btn footer-btn-gh">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                    TomaTeQuila
                </a>
                <a href="https://www.linkedin.com/in/amaro-montero-guti%C3%A9rrez-6212a8239/" target="_blank" rel="noopener" class="footer-btn footer-btn-li">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    LinkedIn
                </a>
                <div class="footer-location">
                    <span>📍</span>
                    Viña del Mar, Chile
                </div>
            </div>
        </div>
    </footer>
<script>
    document.querySelectorAll('.service-card').forEach(card => {
        card.addEventListener('mousemove', (e) => {
            const rect = card.getBoundingClientRect();
            card.style.setProperty('--mx', `${e.clientX - rect.left}px`);
            card.style.setProperty('--my', `${e.clientY - rect.top}px`);
        });
    });
</script>

</Layout>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        overflow-x: hidden;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    /* Services Section */
    .services {
        background: #050810;
        padding: 7rem 0;
        position: relative;
    }

    .services::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
        background-size: 64px 64px;
        pointer-events: none;
    }

    .services::after {
        content: '';
        position: absolute;
        top: -1px; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(99,102,241,0.5), rgba(168,85,247,0.5), transparent);
        pointer-events: none;
    }

    .services-header {
        text-align: center;
        margin-bottom: 4rem;
    }

    .services-label {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: rgba(168, 85, 247, 0.8);
        margin-bottom: 1rem;
    }

    .services-header h2 {
        font-size: 3.5rem;
        font-weight: 900;
        color: white;
        letter-spacing: -1.5px;
        line-height: 1.1;
    }

    .highlight {
        background: linear-gradient(135deg, #a855f7, #3b82f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .services-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
    }

    .service-card {
        position: relative;
        background: rgba(255,255,255,0.03);
        border-radius: 24px;
        padding: 2.5rem;
        border: 1px solid rgba(255,255,255,0.07);
        overflow: hidden;
        transition: transform 0.35s ease, border-color 0.35s ease;
        cursor: default;
        display: flex;
        flex-direction: column;
    }

    /* Gradient border on hover via mask */
    .service-card::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 24px;
        padding: 1px;
        background: linear-gradient(135deg, #a855f7, #6366f1, #3b82f6);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0;
        transition: opacity 0.4s ease;
        pointer-events: none;
    }

    /* Mouse-tracking spotlight */
    .service-card::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 24px;
        background: radial-gradient(400px circle at var(--mx, 50%) var(--my, 50%), rgba(168,85,247,0.07), transparent 65%);
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

    .service-card:hover { transform: translateY(-6px); border-color: transparent; }
    .service-card:hover::before { opacity: 1; }
    .service-card:hover::after  { opacity: 1; }

    /* Large background number */
    .card-num {
        position: absolute;
        top: 1rem;
        right: 1.5rem;
        font-size: 5rem;
        font-weight: 900;
        color: rgba(255,255,255,0.04);
        line-height: 1;
        letter-spacing: -3px;
        transition: color 0.4s ease;
        user-select: none;
    }
    .service-card:hover .card-num { color: rgba(168,85,247,0.08); }

    /* Icon */
    .card-icon-wrap {
        width: 48px; height: 48px;
        background: rgba(168,85,247,0.1);
        border: 1px solid rgba(168,85,247,0.2);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #c084fc;
        margin-bottom: 1.8rem;
        transition: all 0.35s ease;
    }
    .service-card:hover .card-icon-wrap {
        background: rgba(168,85,247,0.18);
        border-color: rgba(168,85,247,0.4);
        color: #d8b4fe;
        transform: scale(1.05);
    }

    .service-card h3 {
        color: white;
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 0.8rem;
        letter-spacing: -0.3px;
    }

    .service-card p {
        color: rgba(255,255,255,0.5);
        line-height: 1.7;
        font-size: 0.92rem;
        margin-bottom: 1.2rem;
    }

    .card-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: auto;
        padding-top: 0.4rem;
    }

    .card-pills span {
        background: rgba(168,85,247,0.08);
        border: 1px solid rgba(168,85,247,0.18);
        color: rgba(168,85,247,0.85);
        padding: 0.2rem 0.65rem;
        border-radius: 50px;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.2px;
        transition: background 0.2s;
    }

    .service-card:hover .card-pills span {
        background: rgba(168,85,247,0.14);
    }

    .card-pills.ai-pills span {
        background: rgba(217,119,87,0.08);
        border-color: rgba(217,119,87,0.2);
        color: rgba(217,119,87,0.9);
    }

    .service-card:hover .card-pills.ai-pills span {
        background: rgba(217,119,87,0.14);
    }

    .ai-icon svg { color: #d97757; }
    .service-card:hover .ai-icon { background: rgba(217,119,87,0.12); border-color: rgba(217,119,87,0.25); }
    .service-card:hover .ai-icon svg { color: #e8845a; }

    @media (max-width: 768px) {
        .services-grid { grid-template-columns: 1fr; }
        .services-header h2 { font-size: 2.5rem; }
    }

    /* Experience Section */
    .experience {
        background: #050810;
        padding: 6rem 0;
        position: relative;
    }

    .experience::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px);
        background-size: 64px 64px;
        pointer-events: none;
    }

    .experience::after {
        content: '';
        position: absolute;
        top: -1px;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(168,85,247,0.4), rgba(99,102,241,0.4), transparent);
        pointer-events: none;
    }

    .exp-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 2rem;
        align-items: start;
    }

    .exp-pair {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        align-items: stretch;
    }

    .exp-col { display: flex; flex-direction: column; gap: 1.5rem; }
    .exp-col-timeline { align-self: start; }
    .exp-col .skills-section { flex: 1; }

    .exp-col-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: rgba(255,255,255,0.25);
        margin-bottom: -0.5rem;
    }

    .experience-left h2 {
        font-size: 2.2rem;
        font-weight: 800;
        color: white;
        margin-bottom: 2rem;
        line-height: 1.1;
    }

    /* Job Timeline */
    .job-timeline {
        position: relative;
    }

    .job-timeline::before {
        content: '';
        position: absolute;
        left: 20px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: linear-gradient(180deg, #a855f7, #3b82f6);
    }

    .job-item {
        position: relative;
        padding-left: 60px;
        margin-bottom: 3rem;
    }

    .job-item::before {
        content: '';
        position: absolute;
        left: 21px;
        top: 8px;
        transform: translateX(-50%);
        width: 12px;
        height: 12px;
        background: #a855f7;
        border-radius: 50%;
        border: 3px solid #0d1117;
    }

    .job-item.current::before {
        background: linear-gradient(135deg, #a855f7, #3b82f6);
        box-shadow: 0 0 16px rgba(168, 85, 247, 0.6);
    }

    .job-badge {
        display: inline-block;
        background: linear-gradient(135deg, #a855f7, #3b82f6);
        color: white;
        padding: 0.3rem 1rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .job-content h3 {
        font-size: 1.3rem;
        font-weight: 700;
        color: white;
        margin-bottom: 0.5rem;
    }

    .company {
        color: #a78bfa;
        font-weight: 600;
        margin-bottom: 0.3rem;
    }

    .period {
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.9rem;
        margin-bottom: 1rem;
    }

    .description {
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.7;
    }

    .description code {
        font-family: 'Courier New', monospace;
        font-size: 0.85em;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 4px;
        padding: 0.1em 0.4em;
        color: rgba(255, 255, 255, 0.8);
    }

    /* Skills Section */
