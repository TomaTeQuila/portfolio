---
import Layout from '../layouts/Layout.astro';
import Personal from '../components/Personal.astro';
import Projects from '../components/Projects.astro';
---

<Layout>
    <Personal />
    
    <!-- Services Section -->
    <section class="services">
        <div class="container">
            <div class="services-header">
				<h2>Desarrollador Full Stack</h2>
            </div>
            
            <div class="services-grid">
                <div class="service-card">
                    <div class="service-icon">💻</div>
                    <h3>Frontend</h3>
                    <p>Desarrollo interfaces modernas con Astro, Tailwind, CSS nativo, Next.js y las últimas tecnologías web para crear experiencias únicas.</p>
                </div>
                
                
                <div class="service-card">
					<div class="service-icon">🤖</div>
                    <h3>Backend</h3>
                    <p>Desarrollador Backend con tecnologías modernas, robustas y escalables, tales como Laravel, Ruby on Rails, Express.js, y demás.</p>
                </div>

				<div class="service-card">
					<div class="service-icon">🤝</div>
					<h3>Teamwork</h3>
					<p>El trabajo en equipo es fundamental, para ello, es importante tener buena comunicación y ser asertivo. Considero que tengo lo mencionado y buenas habilidades blandas.</p>
				</div>
            </div>
        </div>
    </section>

    <!-- Experience & Skills Section -->
    <section class="experience">
        <div class="container">
            <div class="experience-content">
                <div class="experience-left">                    
                    <div class="job-timeline">
                        <div class="job-item current">
                            <div class="job-badge">Actual</div>
                            <div class="job-content">
                                <h3>Integration Analyst Jr.</h3>
                                <p class="company">Buk • Santiago, Chile</p>
                                <p class="period">Dic 2024 - Presente</p>
                                <p class="description">Desarrollo de integraciones en Ruby on Rails para archivos contables, vouchers personalizados y migración de bases de datos externas hacia Buk. Carga histórica de datos desde archivos <code>.bak</code> con reconciliación de fichas de empleados e ítems mediante software interno en C#. Gestión activa de tickets con contacto directo a clientes internos, entregando soluciones ágiles con ciclos de feedback cortos. Uso de flujos de trabajo aumentados con IA (Claude) para creación, supervisión y compounding de skills y commands, mejorando iterativamente la calidad y velocidad de las soluciones.</p>
                            </div>
                        </div>
                        
                        <div class="job-item">
                            <div class="job-content">
                                <h3>IT Support Internship</h3>
                                <p class="company">FSM Ltda. • Viña del Mar</p>
                                <p class="period">Ene 2024 - Abr 2024</p>
                                <p class="description">Soporte técnico y optimización de procesos con IA. Uso de AutoCAD y sistemas ABB 800xA.</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="experience-right">
                    <div class="skills-section">
                        <h3>Tecnologías</h3>
                        <div class="tech-grid">
                            <div class="tech-category">
                                <h4>Backend</h4>
                                <div class="tech-tags">
                                    <span class="tech-tag ruby">Ruby</span>
                                    <span class="tech-tag python">Python</span>
                                    <span class="tech-tag c">C#</span>
                                    <span class="tech-tag java">Java</span>
                                    <span class="tech-tag laravel">Laravel</span>
									<span class="tech-tag express">Express.js</span>
                                    <span class="tech-tag spring">Spring Boot</span>
                                </div>
                            </div>
                            
                            <div class="tech-category">
                                <h4>Frontend</h4>
                                <div class="tech-tags">
                                    <span class="tech-tag js">JavaScript</span>
                                    <span class="tech-tag htmlcss">HTML/CSS</span>
                                    <span class="tech-tag astro">Astro</span>
                                    <span class="tech-tag next">Next.js</span>
                                </div>
                            </div>
                            
                            <div class="tech-category">
                                <h4>Bases de Datos & Otros</h4>
                                <div class="tech-tags">
                                    <span class="tech-tag sql">SQL</span>
                                    <span class="tech-tag">Git</span>
                                    <span class="tech-tag">PHP</span>
                                    <span class="tech-tag lua">Lua</span>
                                    <span class="tech-tag vue">Vue 3</span>
                                    <span class="tech-tag docker">Docker</span>
                                    <span class="tech-tag aws">AWS</span>
                                </div>
                            </div>

                            <div class="tech-category">
                                <h4>IA & Automatización</h4>
                                <div class="tech-tags">
                                    <span class="tech-tag claude">Claude</span>
                                    <span class="tech-tag claudecode">Claude Code</span>
                                    <span class="tech-tag aitools">Skills</span>
                                    <span class="tech-tag aitools">Commands</span>
                                    <span class="tech-tag aitools">Agents</span>
                                    <span class="tech-tag aitools">MCP</span>
                                    <span class="tech-tag aitools">Hooks</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="education-section">
                        <h3>Formación</h3>
                        <div class="education-item">
                            <h4>Ingeniería Civil Informática</h4>
                            <p>UTFSM • En pausa por trabajo</p>
                        </div>
                        <div class="education-item">
                            <h4>Técnico Superior en Informática</h4>
                            <p>UTFSM • 2022-2023</p>
                        </div>
                    </div>
                    
                    <div class="languages-section">
                        <h3>Idiomas</h3>
                        <div class="language-bars">
                            <div class="language-item">
                                <span class="language-name">Español</span>
                                <div class="language-bar">
                                    <div class="language-fill native"></div>
                                </div>
                                <span class="language-level">Nativo</span>
                            </div>
							<div class="language-item">
								<span class="language-name">Francés</span>
								<div class="language-bar">
									<div class="language-fill intermediate"></div>
								</div>
								<span class="language-level">Intermedio</span>
							</div>
                            <div class="language-item">
                                <span class="language-name">Inglés</span>
                                <div class="language-bar">
                                    <div class="language-fill medianamente"></div>
                                </div>
                                <span class="language-level">Intermedio</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
        </div>
    </section>

    <Projects />

    <footer class="site-footer">
        <div class="footer-inner">
            <h2>¿Listo para trabajar juntos?</h2>
            <p>Siempre estoy abierto a nuevas oportunidades y proyectos interesantes</p>
            <div class="footer-contact">
                <a href="mailto:amaroeduard@gmail.com" class="footer-btn">
                    <span>📧</span>
                    amaroeduard@gmail.com
                </a>
                <a href="tel:+56979622341" class="footer-btn">
                    <span>📱</span>
                    +56 9 7962 2341
                </a>
                <div class="footer-location">
                    <span>📍</span>
                    Viña del Mar, Chile
                </div>
            </div>
        </div>
    </footer>
</Layout>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        overflow-x: hidden;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    /* Services Section */
    .services {
        background: #1a1a2e;
        padding: 6rem 0;
        position: relative;
    }

    .services::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Ccircle cx='30' cy='30' r='1'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }

    .services-header {
        text-align: center;
        margin-bottom: 4rem;
    }

    .services-header h2 {
        font-size: 4rem;
        font-weight: 800;
        color: white;
        line-height: 1.1;
        margin-bottom: 2rem;
    }

    .highlight {
        background: linear-gradient(135deg, #a855f7, #3b82f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin-bottom: 4rem;
    }

    .service-card {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 20px;
        padding: 2rem;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.3s ease;
    }

    .service-card:hover {
        transform: translateY(-10px);
        background: rgba(255, 255, 255, 0.1);
    }

    .service-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .service-card h3 {
        color: white;
        font-size: 1.5rem;
        margin-bottom: 1rem;
        font-weight: 600;
    }

    .service-card p {
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.6;
        margin-bottom: 1.5rem;
    }

    .service-link {
        color: #a855f7;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.3s ease;
    }

    .service-link:hover {
        color: #3b82f6;
    }

    /* Experience Section */
    .experience {
        background: #0d1117;
        padding: 6rem 0;
    }

    .experience-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        margin-bottom: 4rem;
    }

    .experience-left h2 {
        font-size: 3rem;
        font-weight: 800;
        color: white;
        margin-bottom: 3rem;
        line-height: 1.1;
    }

    /* Job Timeline */
    .job-timeline {
        position: relative;
    }

    .job-timeline::before {
        content: '';
        position: absolute;
        left: 20px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: linear-gradient(180deg, #a855f7, #3b82f6);
    }

    .job-item {
        position: relative;
        padding-left: 60px;
        margin-bottom: 3rem;
    }

    .job-item::before {
        content: '';
        position: absolute;
        left: 14px;
        top: 8px;
        width: 12px;
        height: 12px;
        background: #a855f7;
        border-radius: 50%;
        border: 3px solid #0d1117;
    }

    .job-item.current::before {
        background: linear-gradient(135deg, #a855f7, #3b82f6);
        box-shadow: 0 0 16px rgba(168, 85, 247, 0.6);
    }

    .job-badge {
        display: inline-block;
        background: linear-gradient(135deg, #a855f7, #3b82f6);
        color: white;
        padding: 0.3rem 1rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .job-content h3 {
        font-size: 1.3rem;
        font-weight: 700;
        color: white;
        margin-bottom: 0.5rem;
    }

    .company {
        color: #a78bfa;
        font-weight: 600;
        margin-bottom: 0.3rem;
    }

    .period {
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.9rem;
        margin-bottom: 1rem;
    }

    .description {
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.7;
    }

    .description code {
        font-family: 'Courier New', monospace;
        font-size: 0.85em;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 4px;
        padding: 0.1em 0.4em;
        color: rgba(255, 255, 255, 0.8);
    }

    /* Skills Section */
    .skills-section {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 2rem;
        border-radius: 20px;
        margin-bottom: 1.5rem;
    }

    .skills-section h3,
    .education-section h3,
    .languages-section h3 {
        font-size: 1.3rem;
        font-weight: 700;
        color: white;
        margin-bottom: 1.5rem;
    }

    .tech-category {
        margin-bottom: 1.5rem;
    }

    .tech-category h4 {
        color: rgba(255, 255, 255, 0.35);
        font-size: 0.75rem;
        font-weight: 700;
        margin-bottom: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .tech-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .tech-tag {
        padding: 0.4rem 1rem;
        background: rgba(255, 255, 255, 0.07);
        border-radius: 25px;
        font-size: 0.8rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.65);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.3s ease;
    }

    .tech-tag:hover {
        transform: translateY(-2px);
    }

    .tech-tag.ruby    { background: linear-gradient(135deg, #7f1d1d, #ef4444); color: white; border: none; }
    .tech-tag.python  { background: linear-gradient(135deg, #1e3a8a, #3b82f6); color: white; border: none; }
    .tech-tag.c       { background: linear-gradient(135deg, #4c1d95, #8b5cf6); color: white; border: none; }
    .tech-tag.java    { background: linear-gradient(135deg, #7c2d12, #f97316); color: white; border: none; }
    .tech-tag.laravel { background: linear-gradient(135deg, #881337, #fb7185); color: white; border: none; }
    .tech-tag.express { background: linear-gradient(135deg, #1f2937, #6b7280); color: white; border: none; }
    .tech-tag.js      { background: linear-gradient(135deg, #713f12, #f59e0b); color: white; border: none; }
    .tech-tag.htmlcss { background: linear-gradient(135deg, #7c2d12, #1d4ed8); color: white; border: none; }
    .tech-tag.next    { background: linear-gradient(135deg, #111827, #374151); color: white; border: 1px solid rgba(255,255,255,0.15); }
    .tech-tag.astro   { background: linear-gradient(135deg, #312e81, #c026d3); color: white; border: none; }
    .tech-tag.sql     { background: linear-gradient(135deg, #1e40af, #38bdf8); color: white; border: none; }
    .tech-tag.lua     { background: linear-gradient(135deg, #1e1b4b, #6366f1); color: white; border: none; }
    .tech-tag.vue     { background: linear-gradient(135deg, #064e3b, #34d399); color: white; border: none; }
    .tech-tag.spring  { background: linear-gradient(135deg, #14532d, #6db33f); color: white; border: none; }
    .tech-tag.docker  { background: linear-gradient(135deg, #0c4a6e, #2496ed); color: white; border: none; }
    .tech-tag.aws     { background: linear-gradient(135deg, #7c2d12, #ff9900); color: white; border: none; }
    .tech-tag.claude      { background: linear-gradient(135deg, #2d1a0e, #d97757); color: white; border: none; }
    .tech-tag.claudecode  { background: linear-gradient(135deg, #1a0d05, #e8845a); color: white; border: 1px solid rgba(217,119,87,0.4); }
    .tech-tag.aitools     { background: rgba(217, 119, 87, 0.1); color: #e8a987; border: 1px solid rgba(217,119,87,0.25); }

    /* Education Section */
    .education-section {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 2rem;
        border-radius: 20px;
        margin-bottom: 1.5rem;
    }

    .education-item {
        margin-bottom: 1.5rem;
    }

    .education-item h4 {
        font-weight: 600;
        color: white;
        margin-bottom: 0.3rem;
    }

    .education-item p {
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.9rem;
    }

    /* Languages Section */
    .languages-section {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 2rem;
        border-radius: 20px;
    }

    .language-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .language-name {
        min-width: 70px;
        font-weight: 600;
        color: white;
        font-size: 0.9rem;
    }

    .language-bar {
        flex: 1;
        height: 6px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 10px;
        overflow: hidden;
    }

    .language-fill {
        height: 100%;
        border-radius: 10px;
    }

    .language-fill.native {
        width: 100%;
        background: linear-gradient(90deg, #a855f7, #3b82f6);
    }

    .language-fill.intermediate {
        width: 70%;
        background: linear-gradient(90deg, #10b981, #34d399);
    }

    .language-fill.medianamente {
        width: 50%;
        background: linear-gradient(90deg, #10b981, #34d399);
    }

    .language-level {
        min-width: 80px;
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.4);
    }

    /* Footer */
    .site-footer {
        background: #070b10;
        padding: 5rem 0 3rem;
        text-align: center;
    }

    .footer-inner {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .site-footer h2 {
        font-size: 2.5rem;
        font-weight: 800;
        color: white;
        margin-bottom: 1rem;
    }

    .site-footer p {
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.45);
        margin-bottom: 3rem;
    }

    .footer-contact {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .footer-btn {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        padding: 0.85rem 1.8rem;
        background: rgba(255, 255, 255, 0.06);
        border-radius: 50px;
        color: white;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.3s ease;
    }

    .footer-btn:hover {
        background: rgba(168, 85, 247, 0.15);
        border-color: rgba(168, 85, 247, 0.4);
        transform: translateY(-2px);
    }

    .footer-location {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        padding: 0.85rem 1.8rem;
        color: rgba(255, 255, 255, 0.4);
        font-weight: 600;
        font-size: 0.9rem;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .services-header h2 {
            font-size: 2.5rem;
        }

        .services-grid {
            grid-template-columns: 1fr;
        }

        .experience-content {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .experience-left h2 {
            font-size: 2.3rem;
        }

        .footer-contact {
            flex-direction: column;
            align-items: center;
        }

        .site-footer h2 {
            font-size: 2rem;
        }

        .tech-tags {
            justify-content: center;
        }
    }
</style>